#!name =  WeatherKit: 🌤 Alert Override
#!desc = 替换和风天气(qweather.com)预警页面，以 Apple WeatherKit 原生样式呈现预警信息
#!author = VirgilClyne[https://github.com/VirgilClyne],WordlessEcho[https://github.com/WordlessEcho],001[https://github.com/001ProMax]
#!homepage = https://github.com/stellarhalo/WeatherKitAlert
#!icon = https://developer.apple.com/assets/elements/icons/weatherkit/weatherkit-128x128.png
#!category =  WeatherKit
#!version = 1.1.0
#!date = 2026-07-20 16:00:00

[Script]
WeatherKit.alert.response = type=http-response, pattern=^https?:\/\/www\.qweather\.com\/severe-weather\/, requires-body=1, script-path=https://github.com/stellarhalo/WeatherKitAlert/releases/latest/download/alert.bundle.js, argument=

[MITM]
hostname = %APPEND% www.qweather.com
